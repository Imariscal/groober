# ============================================
# VIBRALIVE FRONTEND - ENVIRONMENT CONFIGURATION
# ============================================
# IMPORTANT NOTES:
# 1. This file is the TEMPLATE for .env.local
# 2. DO NOT commit sensitive secrets to version control
# 3. For development, copy this to .env.local and update values
# 4. Next.js automatically loads .env.local (PRIORITY over .env.example)
# ============================================

# API Configuration - RELATIVE PATHS ONLY
# DO NOT use absolute URLs like http://localhost:3001
# Next.js will proxy /api/* requests to the backend via rewrites in next.config.js
# This avoids CORS issues completely
# NEXT_PUBLIC_API_URL is NOT needed - FE uses /api/* relative paths
# Backend is configured via API_BACKEND_URL in next.config.js

NEXT_PUBLIC_APP_NAME=VibraLive
NEXT_PUBLIC_APP_DESCRIPTION=Motor de retención veterinario

# Maps Configuration
# Options: 'leaflet' (default, free) or 'google' (requires API key)
NEXT_PUBLIC_MAPS_PROVIDER=google
NEXT_PUBLIC_MAPS_ENABLED=true

# Google Maps API Key
# Get from: https://console.cloud.google.com/
# Only needed if NEXT_PUBLIC_MAPS_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCPj_1hBavVvcc064q6HLX1i0UJ3Idalmw

# Route Optimizer Microservice
# This is a SEPARATE service that's NOT proxied
# The FE connects directly to it for route optimization
NEXT_PUBLIC_ROUTE_OPTIMIZER_URL=http://localhost:8001

# Development
NODE_ENV=development

