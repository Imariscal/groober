# NODE ENVIRONMENT
NODE_ENV=development

# DATABASE
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USERNAME=vibralive_dev
DATABASE_PASSWORD=vibralive_password
DATABASE_NAME=vibralive_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# WHATSAPP
WHATSAPP_API_TOKEN=your-meta-business-api-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_GRAPH_API_VERSION=v19.0

# REDIS (optional, for queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LOGGING
LOG_LEVEL=debug

# AZURE
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_TENANT_ID=your-tenant-id

# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vivapet.live@gmail.com
SMTP_PASS=vivapet2026@
SMTP_FROM="VibraLive" <no-reply@vibralive.com>

# FRONTEND URL (for invitation links)
FRONTEND_URL=http://localhost:3001
